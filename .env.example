# Server
PORT=8080
EXTERNAL_URL=https://soquery.example.com

# Salesforce Connected App (Authorization Code flow)
SF_DOMAIN=varnish.my.salesforce.com
SF_CLIENT_ID=your-connected-app-consumer-key
SF_CLIENT_SECRET=your-connected-app-consumer-secret

# Database (sqlite: for dev, postgres:// for production)
DATABASE_URL=sqlite:soquery.db

# Security keys (base64-encoded 32-byte keys)
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
JWT_SIGNING_KEY=
